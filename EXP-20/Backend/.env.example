# Copy to ".env" and fill in your values. Do not commit ".env".
#
# Docker Compose (experiment-20/docker-compose.yml) sets DB_* on the backend
# container — you only need this file for local `python run.py` / pytest.

# =============================================================================
# MySQL / MariaDB — set your SQL username and password here
# (Leave SQLALCHEMY_DATABASE_URI empty or delete that line so these are used.)
# =============================================================================
SQLALCHEMY_DATABASE_URI=

DB_DRIVER=mysql+pymysql
DB_USER=your_sql_username
DB_PASSWORD=your_sql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=students_db

# Same as DB_USER / DB_PASSWORD if you prefer these names instead:
# SQL_USERNAME=your_sql_username
# SQL_PASSWORD=your_sql_password

# =============================================================================
# Or use one full connection string (then DB_* above are ignored)
# =============================================================================
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://USER:PASSWORD@localhost:3306/students_db

# =============================================================================
# Or SQLite file (no username/password)
# =============================================================================
# SQLALCHEMY_DATABASE_URI=sqlite:///students.db

# If SQLALCHEMY_DATABASE_URI is empty AND DB_USER/DB_HOST/DB_NAME are incomplete,
# the app falls back to: sqlite:///students.db

# Comma-separated list for browser clients (Netlify URL, localhost, etc.).
# Use * only for development.
CORS_ORIGINS=*
